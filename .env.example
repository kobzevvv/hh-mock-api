PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# Optional runtime mode for future external auth handling.
HH_MOCK_PUBLIC_MODE=true

# Optional synthetic bearer expected by sandbox mode.
HH_MOCK_BEARER_TOKEN=mock_access_token

# Optional deployment metadata.
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
